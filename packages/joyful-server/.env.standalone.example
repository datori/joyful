# Joyful Standalone Server - Environment Configuration
# Copy this file to .env.standalone and fill in the values.
# .env.standalone is gitignored; this example file is committed.

# Port for the standalone server.
# Use 3007 to avoid conflict with happy-server (which uses 3005).
PORT=3007

# Master secret used for auth challenge signing and encryption.
# Generate a strong random value: openssl rand -hex 32
# NOTE: This env var is still named HANDY_MASTER_SECRET (pending rename).
HANDY_MASTER_SECRET=replace-with-a-strong-random-secret-at-least-32-chars

# Directory for PGlite database and app data.
# Defaults to ./data relative to the server working directory if unset.
DATA_DIR=./data
