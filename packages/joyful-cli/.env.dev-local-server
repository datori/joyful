# Use separate dev directory for joyful data
# Useful to allow having separate auth for local dev / production dogfooding
JOYFUL_HOME_DIR=~/.joyful-dev

# Local development server
JOYFUL_SERVER_URL=http://localhost:3007
JOYFUL_WEBAPP_URL=http://localhost:8081

DEBUG=1
# DANGEROUSLY_LOG_TO_SERVER_FOR_AI_AUTO_DEBUGGING=true

# We have this in bin too for production
NODE_NO_WARNINGS=1

