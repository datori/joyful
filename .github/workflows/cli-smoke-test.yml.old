name: CLI Smoke Test

on:
  push:
    branches: [ main ]
    paths:
      - 'packages/joyful-cli/**'
      - '.github/workflows/cli-smoke-test.yml'
  pull_request:
    branches: [ main ]
    paths:
      - 'packages/joyful-cli/**'
      - '.github/workflows/cli-smoke-test.yml'
  workflow_dispatch:

jobs:
  smoke-test-linux:
    runs-on: ubuntu-latest
    strategy:
      matrix:
        node-version: [20, 24]

    steps:
    - name: Checkout code
      uses: actions/checkout@v4

    - name: Setup Node.js ${{ matrix.node-version }}
      uses: actions/setup-node@v4
      with:
        node-version: ${{ matrix.node-version }}
        cache: 'yarn'
        cache-dependency-path: yarn.lock

    - name: Install dependencies
      run: yarn install --immutable

    - name: Build package
      run: yarn workspace joyful build

    - name: Pack package
      run: yarn workspace joyful pack

    - name: Install packed package globally
      run: |
        PACKAGE_FILE=$(ls packages/joyful-cli/*.tgz)
        npm install -g "./$PACKAGE_FILE"

    - name: Test binary execution
      run: |
        # Test that the binary starts successfully
        echo "Testing joyful --help..."
        timeout 30s joyful --help || {
          echo "Error: joyful --help failed or timed out"
          exit 1
        }

        echo "Testing joyful --version..."
        timeout 10s joyful --version || {
          echo "Error: joyful --version failed or timed out"
          exit 1
        }

        echo "Testing joyful doctor..."
        timeout 30s joyful doctor || {
          echo "Error: joyful doctor failed or timed out"
          exit 1
        }

        echo "Testing joyful daemon status..."
        timeout 10s joyful daemon status || {
          echo "Error: joyful daemon status failed or timed out"
          exit 1
        }

        echo "Smoke test passed on Linux!"

  smoke-test-windows:
    runs-on: windows-latest
    strategy:
      matrix:
        node-version: [20, 24]

    steps:
    - name: Checkout code
      uses: actions/checkout@v4

    - name: Setup Node.js ${{ matrix.node-version }}
      uses: actions/setup-node@v4
      with:
        node-version: ${{ matrix.node-version }}
        cache: 'yarn'
        cache-dependency-path: yarn.lock

    - name: Install dependencies
      run: yarn install --immutable

    - name: Build package
      run: yarn workspace joyful build

    - name: Pack package
      run: yarn workspace joyful pack

    - name: Install packed package globally
      shell: cmd
      run: |
        for %%f in (packages\joyful-cli\*.tgz) do npm install -g "%%f"

    - name: Debug npm global installation structure
      shell: cmd
      run: |
        for /f "tokens=*" %%i in ('npm config get prefix') do set NPM_PREFIX=%%i
        echo NPM_PREFIX: %NPM_PREFIX%
        echo Listing npm prefix directory:
        dir "%NPM_PREFIX%" 2>nul || echo Failed to list NPM_PREFIX
        echo.
        echo Checking for node_modules in npm prefix:
        if exist "%NPM_PREFIX%\node_modules" (
          echo Found node_modules directory
          dir "%NPM_PREFIX%\node_modules" 2>nul
          echo.
          echo Checking for joyful package:
          if exist "%NPM_PREFIX%\node_modules\joyful" (
            echo Found joyful package
            dir "%NPM_PREFIX%\node_modules\joyful" 2>nul
            echo.
            echo Checking for dist directory:
            if exist "%NPM_PREFIX%\node_modules\joyful\dist" (
              echo Found dist directory
              dir "%NPM_PREFIX%\node_modules\joyful\dist" 2>nul
            ) else (
              echo No dist directory found
            )
          ) else (
            echo No joyful package found
          )
        ) else (
          echo No node_modules directory found
        )

    - name: Test binary execution
      shell: cmd
      run: |
        @echo on

        rem Get npm global prefix and add to PATH
        for /f "tokens=*" %%i in ('npm config get prefix') do set NPM_PREFIX=%%i
        set PATH=%NPM_PREFIX%;%PATH%
        echo NPM_PREFIX: %NPM_PREFIX%
        echo Current PATH: %PATH%

        rem Debug: Check if joyful exists in various locations
        echo Checking for joyful binary...
        where joyful 2>nul && echo Found joyful in PATH || echo joyful not found in PATH
        if exist "%NPM_PREFIX%\joyful.cmd" echo Found joyful.cmd in NPM_PREFIX
        if exist "%NPM_PREFIX%\node_modules\.bin\joyful.cmd" echo Found joyful.cmd in .bin directory
        dir "%NPM_PREFIX%\*happy*" 2>nul || echo No joyful files found in NPM_PREFIX

        rem Debug: Check the actual contents and encoding of the installed file
        if exist "%NPM_PREFIX%\joyful.cmd" (
          echo File size and type:
          dir "%NPM_PREFIX%\joyful.cmd"
          echo.
          echo First few lines of the file:
          type "%NPM_PREFIX%\joyful.cmd" | head -5
          echo.
          echo Hex dump of first 50 bytes to check line endings:
          powershell -Command "Get-Content '%NPM_PREFIX%\joyful.cmd' -Encoding Byte -TotalCount 50 | ForEach-Object { '{0:X2}' -f $_ } | Join-String -Separator ' '"
          echo.
          echo Testing with direct path...
          "%NPM_PREFIX%\joyful.cmd" --help
        ) else (
          echo Testing joyful --help...
          joyful --help
        )
        if errorlevel 1 (
          echo Error: joyful --help failed
          exit /b 1
        )

        rem Test version
        if exist "%NPM_PREFIX%\joyful.cmd" (
          "%NPM_PREFIX%\joyful.cmd" --version
        ) else (
          joyful --version
        )
        if errorlevel 1 (
          echo Error: joyful --version failed
          exit /b 1
        )

        rem Test doctor
        echo Testing joyful doctor...
        if exist "%NPM_PREFIX%\joyful.cmd" (
          "%NPM_PREFIX%\joyful.cmd" doctor
        ) else (
          joyful doctor
        )
        if errorlevel 1 (
          echo Error: joyful doctor failed
          exit /b 1
        )

        rem Test daemon status
        echo Testing joyful daemon status...
        if exist "%NPM_PREFIX%\joyful.cmd" (
          "%NPM_PREFIX%\joyful.cmd" daemon status
        ) else (
          joyful daemon status
        )
        if errorlevel 1 (
          echo Error: joyful daemon status failed
          exit /b 1
        )

        echo Smoke test passed on Windows!

# We don't need a smoke test for macOS because most contributors are developing on macOS.
